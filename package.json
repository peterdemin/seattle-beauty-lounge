{
	"type": "module",
	"scripts": {
		"dev": "vite",
		"admindev": "vite --config vite.config.admin.js",
		"admincss": "npx tailwindcss -c admin/tailwind.config.admin.js -o admin/style.css -i source/styles/input.css -w",
		"development": "vite build --mode development",
		"staging": "vite build --mode staging",
		"production": "vite build --mode production",
		"appointmentdevelopment": "vite build --config vite.config.appointment.js --mode development",
		"appointmentstaging": "vite build --config vite.config.appointment.js --mode staging",
		"appointmentproduction": "vite build --config vite.config.appointment.js --mode production",
		"e2e": "npm exec -- playwright test",
		"admindevelopment": "vite build --config vite.config.admin.js --mode development",
		"adminstaging": "vite build --config vite.config.admin.js --mode staging",
		"adminproduction": "vite build --config vite.config.admin.js --mode production",
		"test:js": "jest --runInBand",
		"test:js:coverage": "jest --runInBand --coverage && node tools/filter_js_coverage.mjs"
	},
	"devDependencies": {
		"@babel/core": "^7.26.0",
		"@babel/preset-env": "^7.26.0",
		"@babel/preset-react": "^7.25.9",
		"@biomejs/biome": "1.9.4",
		"@playwright/test": "1.50.0",
		"@testing-library/react": "^16.1.0",
		"@vitejs/plugin-react": "^4.3.4",
		"babel-jest": "^29.7.0",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"tailwindcss": "^3.4.17",
		"vite": "^6.0.5"
	},
	"dependencies": {
		"@sentry/react": "^8.47.0",
		"@square/web-sdk": "^2.0.1",
		"react": "^19.0.0",
		"react-day-picker": "^9.4.4",
		"react-dom": "^19.0.0",
		"react-hook-form": "^7.54.2"
	}
}
